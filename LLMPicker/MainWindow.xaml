<Window x:Class="LLMPicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Copilot LLM Picker"
        Width="460"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        FontSize="16">

    <StackPanel Margin="14,12,14,12">

        <!-- Provider dropdown -->
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Provider:" Width="72" VerticalAlignment="Center"/>
            <ComboBox x:Name="ProviderCombo" SelectionChanged="ProviderCombo_SelectionChanged"/>
        </DockPanel>

        <!-- Model dropdown — shown only for Ollama/FoundryLocal -->
        <DockPanel x:Name="ModelRow" Margin="0,0,0,8" Visibility="Collapsed">
            <TextBlock Text="Model:" Width="72" VerticalAlignment="Center"/>
            <ComboBox x:Name="ModelCombo" SelectionChanged="ModelCombo_SelectionChanged"/>
        </DockPanel>

        <Separator Margin="0,2,0,8"/>

        <!-- Current values -->
        <TextBlock Text="Current" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border Background="#F3F3F3" CornerRadius="4" Padding="8,6" Margin="0,0,0,10"
                BorderBrush="#DCDCDC" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="BASE_URL:" Foreground="#666" FontSize="13"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CurrentBaseUrl" FontSize="13" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="MODEL:" Foreground="#666" FontSize="13" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CurrentModel" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0"/>
            </Grid>
        </Border>

        <!-- After Apply preview -->
        <TextBlock Text="After Apply" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border Background="#EBF3FB" CornerRadius="4" Padding="8,6" Margin="0,0,0,12"
                BorderBrush="#C5DCF0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="BASE_URL:" Foreground="#666" FontSize="13"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PreviewBaseUrl" FontSize="13" TextWrapping="Wrap"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="MODEL:" Foreground="#666" FontSize="13" Margin="0,3,0,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PreviewModel" FontSize="13" TextWrapping="Wrap" Margin="0,3,0,0"/>
            </Grid>
        </Border>

        <!-- Apply -->
        <Button x:Name="ApplyBtn" Content="Apply" Width="80"
                HorizontalAlignment="Right" Click="ApplyBtn_Click"
                Padding="0,4"/>
    </StackPanel>
</Window>
